# =============================================================================
# MetricTide — root environment template
# -----------------------------------------------------------------------------
# Copy to `.env` (`cp .env.example .env`) and adjust as needed.
# These values are consumed by docker-compose.yml and passed to services.
# NEVER commit a real `.env` file.
# =============================================================================

# ---- General ----
COMPOSE_PROJECT_NAME=metrictide
ENVIRONMENT=development                 # development | staging | production
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                      # console | json

# ---- PostgreSQL ----
POSTGRES_USER=metrictide
POSTGRES_PASSWORD=metrictide
POSTGRES_DB=metrictide
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full async DSN used by the API (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://metrictide:metrictide@postgres:5432/metrictide

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---- API service ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
API_SECRET_KEY=change-me-in-production

# ---- Web service ----
WEB_PORT=3000
# Browser-facing API base URL (must be reachable from the user's browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Server-side API base URL (container-to-container)
API_INTERNAL_BASE_URL=http://api:8000

# ---- Kafka (DEFERRED — placeholder only, not started by default) ----
# See docs/adr/0001-defer-kafka.md
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
