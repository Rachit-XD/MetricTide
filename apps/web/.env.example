# =============================================================================
# MetricTide Web — environment template
# Copy to `.env.local` for local development.
# =============================================================================

# Browser-facing API base URL (exposed to the client bundle).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Server-side (RSC / route handlers) API base URL. In Docker this is the
# internal service name; locally it usually matches the public URL.
API_INTERNAL_BASE_URL=http://localhost:8000
