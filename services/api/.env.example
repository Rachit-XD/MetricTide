# =============================================================================
# MetricTide API — environment template
# Copy to `.env` for local (non-Docker) development.
# In Docker, these are provided by the root .env via docker-compose.
# =============================================================================

ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                 # console | json

API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
API_CORS_ORIGINS=http://localhost:3000

# Async SQLAlchemy DSN. For local dev outside Docker, use localhost.
DATABASE_URL=postgresql+asyncpg://metrictide:metrictide@localhost:5432/metrictide

REDIS_URL=redis://localhost:6379/0

# ---- Reddit ingestion (public JSON API; no OAuth required) ----
REDDIT_BASE_URL=https://www.reddit.com
REDDIT_USER_AGENT=MetricTide/0.1 (+https://github.com/Rachit-XD/MetricTide)
REDDIT_FETCH_LIMIT=100
REDDIT_SUBREDDITS=programming,artificial,MachineLearning,startups

# ---- Hacker News ingestion (public Firebase API; no auth required) ----
HACKERNEWS_BASE_URL=https://hacker-news.firebaseio.com/v0
HACKERNEWS_USER_AGENT=MetricTide/0.1 (+https://github.com/Rachit-XD/MetricTide)
HACKERNEWS_FETCH_LIMIT=50

# Kafka — deferred. Leave unset until the streaming pipeline is enabled.
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
